import AuditInterface as iface;

contract AuditProxy
{
	@global address owner;
	@global map<hash, uint64> impl_map;
	@global map<uint64, array<hash>> app_bindings;
	@global map<hash, array<uint64>> check_bindings;

	@global function on_deploy(address addr)
	{
		owner = addr;
	}

	@global function audit(iface.AuditContext ctx) public export
	{
		if(!app_bindings.has(ctx.app_cvid))
		{
			return;
		}
		array<hash> names = app_bindings[ctx.app_cvid];
		for(uint32 i = 0u; i < names.length(); i++)
		{
			if(impl_map.has(names[i]))
			{
				uint64 impl_cid = impl_map[names[i]];
				iface.IAuditCheck impl = iface.IAuditCheck(impl_cid);
				if(impl.__valid())
				{
					__debug.assert(impl.check(ctx), "audit check failed");
				}
			}
		}
	}

	@global function query_bindings(hash check_name) public export
	{
		if(check_bindings.has(check_name))
		{
			array<uint64> cvids = check_bindings[check_name];
			for(uint32 i = 0u; i < cvids.length(); i++)
			{
				__debug.print("bound app_cvid:", cvids[i]);
			}
		}
	}

	@address function register(hash check_name, uint64 impl_cid) public export
	{
		address sender = __transaction.get_sender();
		relay@global(^check_name, ^impl_cid, ^sender)
		{
			__debug.assert(sender == owner, "only owner");
			impl_map[check_name] = impl_cid;
		}
	}

	@address function unregister(hash check_name) public export
	{
		address sender = __transaction.get_sender();
		relay@global(^check_name, ^sender)
		{
			__debug.assert(sender == owner, "only owner");
			__debug.assert(!check_bindings.has(check_name),
				"cannot unregister: still bound to app contracts");
			if(impl_map.has(check_name))
			{
				impl_map.erase(check_name);
			}
		}
	}

	@address function bind(uint64 app_cvid, hash audit_name) public export
	{
		address sender = __transaction.get_sender();
		relay@global(^app_cvid, ^audit_name, ^sender)
		{
			__debug.assert(sender == owner, "only owner");
			__debug.assert(impl_map.has(audit_name), "audit type not registered");
			if(!app_bindings.has(app_cvid))
			{
				array<hash> names;
				names.push(audit_name);
				app_bindings[app_cvid] = names;
			}
			else
			{
				array<hash> names = app_bindings[app_cvid];
				for(uint32 i = 0u; i < names.length(); i++)
				{
					if(names[i] == audit_name) { return; }
				}
				names.push(audit_name);
				app_bindings[app_cvid] = names;
			}
			if(check_bindings.has(audit_name))
			{
				array<uint64> cvids = check_bindings[audit_name];
				cvids.push(app_cvid);
				check_bindings[audit_name] = cvids;
			}
			else
			{
				array<uint64> cvids;
				cvids.push(app_cvid);
				check_bindings[audit_name] = cvids;
			}
		}
	}

	@address function unbind(uint64 app_cvid, hash audit_name) public export
	{
		address sender = __transaction.get_sender();
		relay@global(^app_cvid, ^audit_name, ^sender)
		{
			__debug.assert(sender == owner, "only owner");
			if(app_bindings.has(app_cvid))
			{
				array<hash> old_names = app_bindings[app_cvid];
				array<hash> new_names;
				bool found = false;
				for(uint32 i = 0u; i < old_names.length(); i++)
				{
					if(old_names[i] == audit_name)
					{
						found = true;
					}
					else
					{
						new_names.push(old_names[i]);
					}
				}
				if(found)
				{
					app_bindings[app_cvid] = new_names;
					if(check_bindings.has(audit_name))
					{
						array<uint64> old_cvids = check_bindings[audit_name];
						array<uint64> new_cvids;
						for(uint32 i = 0u; i < old_cvids.length(); i++)
						{
							if(old_cvids[i] != app_cvid)
							{
								new_cvids.push(old_cvids[i]);
							}
						}
						if(new_cvids.length() == 0u32)
						{
							check_bindings.erase(audit_name);
						}
						else
						{
							check_bindings[audit_name] = new_cvids;
						}
					}
				}
			}
		}
	}
}
