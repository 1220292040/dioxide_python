import AuditInterface as iface;

contract KycAudit implements iface.IAuditCheck
{
	@global map<address, bool> verified;

	@global function bool check(iface.AuditContext ctx) public export
	{
		return verified.has(ctx.sender) && verified[ctx.sender];
	}

	@address function approve(address addr) public export
	{
		relay@global(^addr) { verified[addr] = true; }
	}

	@address function revoke(address addr) public export
	{
		relay@global(^addr) { verified.erase(addr); }
	}
}
